        {
          "name": "Lister (N+1 voit ses managés)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/employees/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_n1}}" }]
          }
        },
        {
          "name": "Lister (DG voit tout)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/employees/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Lister (Directeur voit son dép.)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/employees/",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
