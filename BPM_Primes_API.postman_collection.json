          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nouveau@blueline.mg\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"TOKEN_REÇU_PAR_EMAIL\",\n  \"new_password\": \"nouveauMot2Passe123\"\n}"
            }
          }
        }
      ]
    },
    {
