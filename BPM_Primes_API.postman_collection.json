{
  "info": {
    "name": "BPM Primes API",
    "description": "Collection pour tester l'API BPM Primes Blueline",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Liste des utilisateurs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/",
            "header": []
          }
        },
        {
          "name": "Créer un utilisateur",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/users/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test.user@blueline.com\",\n  \"name\": \"Utilisateur Test\",\n  \"poste\": \"Test Poste\",\n  \"department\": \"DSI\",\n  \"is_validator_n1\": false,\n  \"is_directeur\": false,\n  \"is_drh\": false,\n  \"is_dg\": false\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Liste des employés",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/employees/",
            "header": []
          }
        },
        {
          "name": "Lister par département",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/employees/?department=DSI",
            "header": []
          }
        },
        {
          "name": "Créer un employé",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/employees/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matricule\": \"EMP003\",\n  \"name\": \"Nouvel Employé\",\n  \"department\": \"DSI\",\n  \"manager_id\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Bonuses (Primes)",
      "item": [
        {
          "name": "Liste des primes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/bonuses/",
            "header": []
          }
        },
        {
          "name": "Lister par statut",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/bonuses/?status=Initialisé",
            "header": []
          }
        },
        {
          "name": "Créer une prime mensuelle",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/bonuses/?user_id=1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": 1,\n  \"month\": 5,\n  \"year\": 2026,\n  \"bonus_type\": \"mensuel\",\n  \"performance_score\": 85.5,\n  \"absences\": 2,\n  \"retard\": 1,\n  \"prime_mensuel_amount\": 150000,\n  \"total_amount\": 150000\n}"
            }
          }
        },
        {
          "name": "Créer prime astreinte",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/bonuses/?user_id=1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": 1,\n  \"month\": 5,\n  \"year\": 2026,\n  \"bonus_type\": \"astreinte\",\n  \"nb_jours_astreinte\": 5,\n  \"taux_jour\": 30000,\n  \"prime_astreinte_amount\": 150000,\n  \"total_amount\": 150000\n}"
            }
          }
        },
        {
          "name": "Créer prime commission",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/bonuses/?user_id=1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": 2,\n  \"month\": 5,\n  \"year\": 2026,\n  \"bonus_type\": \"commission\",\n  \"ca_realise\": 50000000,\n  \"ca_objectif\": 100000000,\n  \"taux_commission\": 2.5,\n  \"commission_amount\": 1250000,\n  \"total_amount\": 1250000\n}"
            }
          }
        },
        {
          "name": "Valider une prime (N+1)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/bonuses/1/validate?step=N1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bonus_id\": 1,\n  \"validator_id\": 1,\n  \"step\": \"N1\",\n  \"action\": \"VALIDER\"\n}"
            }
          }
        },
        {
          "name": "Rejeter une prime",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/bonuses/1/validate?step=N1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bonus_id\": 1,\n  \"validator_id\": 1,\n  \"step\": \"N1\",\n  \"action\": \"REJETER\",\n  \"motif_rejet\": \"Score insuffisant\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Documentation API",
      "item": [
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/docs",
            "header": []
          }
        },
        {
          "name": "OpenAPI JSON",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/openapi.json",
            "header": []
          }
        }
      ]
    }
  ]
}
